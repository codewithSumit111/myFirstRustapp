# Environment Variables
# Copy this file to .env and fill in the values

# ─── Contract Addresses ────────────────────
# Deployed EventTicketNFT contract address (Arbitrum Sepolia)
NEXT_PUBLIC_NFT_ADDRESS=

# URL of the ERC721 deployment API
ERC721_DEPLOYMENT_API_URL=http://localhost:4001

# ─── Wallet Connection ─────────────────────
# WalletConnect Cloud project ID for wallet connections (required)
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Application name displayed in wallet dialogs
NEXT_PUBLIC_APP_NAME=EventTicket NFT